<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Verify your email</title>
    <style>
      body { margin:0; padding:0; font-family: "Segoe UI", Roboto, "Helvetica Neue", Arial; background:linear-gradient(180deg,#fbfdff,#f3f7ff); color:#0b1220; }
      .wrap { max-width:720px; margin:28px auto; padding:22px; }
      .card {
        background: linear-gradient(180deg,#ffffff, #ffffff);
        border-radius:18px; overflow:hidden; box-shadow: 0 10px 30px rgba(16,24,40,0.08);
        display:flex; gap:0; align-items:stretch;
      }
      .left {
        flex: 1 1 58%;
        padding:36px;
      }
      .right {
        width:240px;
        background: linear-gradient(135deg,#ffecd2,#fcb69f);
        padding:20px; display:flex; align-items:center; justify-content:center;
      }
      .logo { width:56px; height:56px; object-fit:cover; border-radius:12px; }
      h1 { margin:0 0 8px; font-size:22px; color:#0b1220; }
      p.lead { margin:12px 0 18px; color:#374151; line-height:1.6; }
      .verify-btn {
        display:inline-block; padding:12px 24px; border-radius:12px; text-decoration:none;
        font-weight:700; background:linear-gradient(90deg,#7c3aed,#3b82f6); color:#fff;
        box-shadow: 0 8px 24px rgba(59,130,246,0.18);
      }
      .small { font-size:13px; color:#6b7280; margin-top:14px; }
      .foot { text-align:center; margin-top:14px; font-size:13px; color:#94a3b8; }
      .decor {
        width:160px; height:160px; border-radius:50%; background:rgba(255,255,255,0.15);
        display:flex; align-items:center; justify-content:center; font-size:40px; color:#fff;
        box-shadow: inset 0 -10px 30px rgba(255,255,255,0.06);
      }
      a.link { color:inherit; text-decoration:underline; }
      @media (max-width:640px) {
        .card { flex-direction:column; }
        .right { width:100%; padding:22px 18px; }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="card" role="article" aria-label="Khubsurat verification email">
        <div class="left">
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:18px;">
            <% if (logoUrl) { %>
              <img class="logo" src="<%= logoUrl %>" alt="<%= companyName %> logo" />
            <% } %>
            <div>
              <div style="font-size:13px; color:#9aa4b2; font-weight:600">Welcome to</div>
              <div style="font-weight:700; font-size:16px;"><%= companyName || "Kyra IT Solutions" %></div>
            </div>
          </div>

          <h1>Hello <%= userName || "Dear" %> 👋</h1>
          <p class="lead">We’re thrilled you joined us. Let’s confirm your email so you can explore everything <strong><%= companyName || "Kyra CRM" %></strong> offers.</p>

          <a class="verify-btn" href="<%= verificationLink %>" target="_blank" rel="noopener">Confirm my email</a>

          <p class="small">This link will expire in 24 hours. If the button doesn't work, copy this URL into your browser:</p>
          <p style="word-break:break-all;"><a class="link" href="<%= verificationLink %>"><%= verificationLink %></a></p>

          <p class="small">Questions? Reach out at <a class="link" href="mailto:<%= supportEmail %>"><%= supportEmail || kyraitsolutions@gmail.com %></a></p>

          <div class="foot">With love — <strong><%= companyName || "Kyra Team" %></strong> • © <%= year || new Date().getFullYear() %></div>
        </div>

        <div class="right" aria-hidden="true">
          <div style="text-align:center;">
            <div class="decor">✨</div>
            <div style="margin-top:12px; font-weight:600; color:#fff">You're almost there</div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
